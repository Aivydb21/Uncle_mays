# Google Ads Conversion Tracking Environment Variables
# Copy these to your .env file and populate with actual values

# Core Google Ads API credentials (already configured in ~/.claude/google-ads-config.json)
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_CUSTOMER_ID=your_customer_id
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_login_customer_id

# Conversion Action ID (run setup-google-ads-conversion-action task to get this)
# Leave blank initially, set after running setup task
GOOGLE_ADS_CONVERSION_ACTION_ID=

# Existing Stripe/Apollo/Mailchimp credentials (already configured)
# STRIPE_API_KEY=sk_live_...
# APOLLO_API_KEY=...
# MAILCHIMP_API_KEY=...
